{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "mode": "full",
  "extends": [
    "config:recommended"
  ],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "rust dependencies (minor)",
      "groupSlug": "rust-deps-minor",
      "automerge": true
    },
    {
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["major"],
      "groupName": "rust dependencies (major)",
      "groupSlug": "rust-deps-major"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "groupSlug": "gh-actions",
      "automerge": true
    },
    {
      "matchManagers": ["pip_requirements", "pep621"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "python dependencies (minor)",
      "groupSlug": "python-deps-minor",
      "automerge": true
    },
    {
      "matchManagers": ["pip_requirements", "pep621"],
      "matchUpdateTypes": ["major"],
      "groupName": "python dependencies (major)",
      "groupSlug": "python-deps-major"
    }
  ]
}
